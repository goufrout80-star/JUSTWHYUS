# Copy to .env and fill in your real values.
# NEVER commit the actual .env file.

# ─── Supabase — from Project Settings → API ──────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Secret Admin Path ───────────────────────────────────────
# The URL path where the admin login lives (instead of /admin).
# Must be: lowercase letters, numbers, hyphens, underscores only.
# Change this to a long random string known only to admins.
# Rotate periodically (e.g. every quarter).
#
# Example: VITE_ADMIN_PATH=neo-x7k9m2q8-access
# Example: VITE_ADMIN_PATH=portal-aurax-1a2b3c4d
VITE_ADMIN_PATH=ctrl-x7k9m2q8-access
